{
  "model": "haiku",
  "permissions": {
    "deny": [
      "Read(.env*)",
      "Read(*.pem)",
      "Read(*.key)",
      "Edit(.env*)",
      "Edit(*.pem)",
      "Edit(*.key)",
      "Write(.env*)",
      "Write(*.pem)",
      "Write(*.key)",
      "Read(credentials*)",
      "Edit(credentials*)",
      "Write(credentials*)",
      "Read(secret*)",
      "Edit(secret*)",
      "Write(secret*)"
    ]
  },
  "env": {
    "PYTHONIOENCODING": "utf-8"
  },
  "hooks": {
    "UserPromptSubmit": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "python \".claude/hooks/branch_guard/branch_guard.py\"",
            "statusMessage": "Checking git branch..."
          }
        ]
      }
    ],
    "PreToolUse": [
      {
        "matcher": "Edit|Write",
        "hooks": [
          {
            "type": "command",
            "command": "python \".claude/hooks/check_file_edit.py\""
          }
        ]
      }
    ]
  }
}